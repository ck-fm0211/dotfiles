#!/bin/bash
# prepare-commit-msg フック: コミットメッセージにブランチ名からチケット番号を自動挿入
#
# ブランチ名が "feature/TICKET-123-description" の形式の場合、
# コミットメッセージの末尾に "(refs: TICKET-123)" を追加する

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"

# マージ・スカッシュ・修正コミットの場合はスキップ
if [ "$COMMIT_SOURCE" = "merge" ] || [ "$COMMIT_SOURCE" = "squash" ] || [ "$COMMIT_SOURCE" = "commit" ]; then
  exit 0
fi

# 現在のブランチ名を取得
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

# ブランチ名からチケット番号を抽出
# 対応パターン: PROJ-123, feat/PROJ-123, feature/PROJ-123-description 等
TICKET=$(echo "$BRANCH" | grep -oE '[A-Z]+-[0-9]+' | head -1)

if [ -n "$TICKET" ]; then
  CURRENT_MSG=$(cat "$COMMIT_MSG_FILE")
  # すでにチケット番号が含まれていればスキップ
  if ! echo "$CURRENT_MSG" | grep -qF "$TICKET"; then
    # コメント行（#）の前に挿入
    perl -i -pe "s/^(# .*\n)/\n# refs: $TICKET\n\$1/ if \$. == 1" "$COMMIT_MSG_FILE" 2>/dev/null || true
  fi
fi

exit 0
