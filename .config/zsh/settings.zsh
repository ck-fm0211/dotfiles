#!/bin/zsh
# settings.zsh - Zsh オプション設定

# ============================================================
# ヒストリ設定
# ============================================================
export HISTSIZE=200000    # メモリ上に保存するコマンド数
export SAVEHIST=200000    # ファイルに保存するコマンド数

setopt hist_ignore_all_dups  # 重複するコマンドは古いほうを削除
setopt hist_ignore_dups      # 直前と同じコマンドは追加しない
setopt hist_ignore_space     # スペースで始まるコマンドはヒストリに追加しない
setopt hist_reduce_blanks    # 余分な空白を詰めて記録
setopt hist_verify           # ヒストリ展開後に確認ステップを挟む
setopt append_history        # ヒストリを追記（上書きしない）
setopt inc_append_history    # リアルタイムでヒストリファイルに追記
setopt share_history         # 複数の Zsh インスタンスでヒストリを共有
setopt extended_history      # タイムスタンプをヒストリに記録

# ============================================================
# 入力・編集
# ============================================================
setopt correct               # コマンドのスペルを訂正（候補を提示）
setopt interactive_comments  # '#' 以降をコメントとして扱う
setopt magic_equal_subst     # '=' の後をファイル名展開する
setopt complete_in_word      # カーソル位置でも補完を実行
setopt no_auto_remove_slash  # 補完後の末尾スラッシュを保持

# ============================================================
# 表示・UI
# ============================================================
setopt no_beep               # ビープ音を鳴らさない
setopt no_nomatch            # グロブが一致しなくてもエラーにしない（コマンドを実行）
setopt auto_cd               # ディレクトリ名だけで cd する
setopt auto_pushd            # cd 時に自動的にディレクトリスタックに追加
setopt pushd_ignore_dups     # 重複したディレクトリはスタックに追加しない
setopt pushd_silent          # pushd/popd で表示しない
setopt print_exit_value      # 終了コードが 0 でない場合に表示

# ============================================================
# グロブ展開
# ============================================================
setopt extended_glob         # 拡張グロブ（^, ~, # など）を有効化
setopt glob_dots             # ドットファイルもグロブの対象に含める（明示的な . 不要）
setopt numeric_glob_sort     # グロブの数値部分を数値としてソート

# ============================================================
# ジョブ制御
# ============================================================
setopt long_list_jobs        # ジョブを詳細表示
setopt auto_resume           # バックグラウンドジョブを同名コマンドで再開

# ============================================================
# 補完システム
# ============================================================
setopt always_to_end         # 補完後にカーソルを末尾に移動
setopt list_packed           # 補完候補を詰めて表示
setopt menu_complete         # 最初の候補を自動選択しない（Tab で選択）

# ============================================================
# リダイレクト・パイプ
# ============================================================
setopt multios               # 複数のリダイレクト先を指定可能（tee のように動作）
