root = true

# すべてのファイルへのデフォルト
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# Python
[*.py]
indent_size = 4
max_line_length = 120

# Makefile はタブ必須
[Makefile]
indent_style = tab

# シェルスクリプト
[*.sh]
indent_size = 2

# YAML / TOML
[*.{yaml,yml,toml}]
indent_size = 2

# Markdown: 末尾スペースを保持（改行に意味を持つ場合がある）
[*.md]
trim_trailing_whitespace = false

# JSON
[*.json]
indent_size = 2

# Go はタブ
[*.go]
indent_style = tab

# Terraform
[*.tf]
indent_size = 2
